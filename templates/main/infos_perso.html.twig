{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/global.css') }}">
    <link rel="stylesheet" href="{{ asset('css/infos_perso.css') }}">
{% endblock %}

{% block title %}
    {% trans %}main.infos_perso.titlePage{% endtrans %} {# Infos_perso #}
{% endblock %}

{% block body %}
<main id="infos_perso_body">
    <aside>
        <img src="{{ asset('images/Ma_photo.png') }}" title="ma photo" alt="photo">
    </aside>
    <div>
        <h2>{% trans %}Qui suis-je ?{% endtrans %}</h2>
        <p>
            {% trans %}Mon nom est Timothée Dagand.{% endtrans %}<br>
            {% trans %}Je suis un étudiant en informatique. Je sais programmer dans les langages Java, HTML, CSS, SQL,
                    C, C++, javascript, typescript, PHP et l'assembleur.{% endtrans %}<br>
            {% trans %}Je maîtrise les bases de l'administration de systèmes informatiques.{% endtrans %}
        </p>
    </div>
    <div>
        <h3>{% trans %}Quelle type d'offre ?{% endtrans %}</h3>
        <p>
            {% trans %}Je serai plus performant dans la programmation. Je peux aussi apprendre de nouvelles choses.{% endtrans %}
        </p>
    </div>
</main>
{% endblock %}
