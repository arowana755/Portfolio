{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/global.css') }}">
    <link rel="stylesheet" href="{{ asset('css/contact.css') }}">
{% endblock %}

{% block title %}
    {% trans %}main.contact.titlePage{% endtrans %} {# Contact #}
{% endblock %}

{% block body %}
<main id="contact_body">
    <div>
        <h2>{% trans %}main.contact.titreVue{% endtrans %}</h2> {# Comment me contacter ? #}
        <img id="comm" class="contact_image" src="{{ asset('images/comm.png') }}" alt="parler"/>
        <p>
            {% trans %}main.contact.comment{% endtrans %}<br> {# Vous pouvez me contacter grâce à mon téléphone portable ou à mon e-mail. #}
            {% trans %}main.contact.lequel{% endtrans %} {# Ma préférence personnelle tend vers le mail. #}
        </p>
    </div>
    <div>
        <h2>{% trans %}main.contact.titreDisplay{% endtrans %}</h2> {# Contact : #}
        <img id="telephone" class="contact_image" src="{{ asset('images/telephone.png') }}" alt="téléphone">
        <p>
            {% trans %}main.contact.tel{% endtrans %}<br> {# Téléphone : 06 01 87 60 36 #}
            E-mail    : silure.38@gmail.com
        </p>
    </div>
</main>
{% endblock %}
