{% extends 'base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/global.css') }}">
    <link rel="stylesheet" href="{{ asset('css/contact.css') }}">
{% endblock %}

{% block title %}
    {% trans %}main.contact.titlePage{% endtrans %} {# Contact #}
{% endblock %}

{% block body %}
<main id="contact_body">
    <aside>
        <img id="telephone" src="{{ asset('images/telephone.png') }}" alt="téléphone">
    </aside>
    <div>
        <h2>{% trans %}main.contact.titreVue{% endtrans %}</h2> {# Comment me contacter ? #}
        <p>
            {% trans %}main.contact.comment{% endtrans %}<br> {# Vous pouvez me contacter grâce à mon téléphone portable ou à mon e-mail. #}
            {% trans %}main.contact.lequel{% endtrans %} {# Ma préférence personnelle tend vers le mail. Je ne serai pas toujours disponible pour le télépone,
                mais je garde toujours ma boîte  mail ouverte dans un onglet en utilisant un appareil électronique et je
                peux donc répondre rapidement. #}
        </p>
    </div>
    <div>
        <h3>{% trans %}main.contact.titreDisplay{% endtrans %}</h3> {# Contact : #}
        <p>
            {% trans %}main.contact.tel{% endtrans %}<br> {# Téléphone : 06 01 87 60 36 #}
            E-mail    : silure.38@gmail.com
        </p>
    </div>
</main>
{% endblock %}
