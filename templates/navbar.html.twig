{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/header.css') }}">
{% endblock %}

{% block js %}
    <script src="{{ asset('js/selectLocale.js') }}"></script>
{% endblock %}

{% block body %}
<header>
    <nav>
        <span id="lien_accueil">
            <a href="{{ path('port_main') }}">Portfolio</a>
        </span>
        <div id="links-container">
            <ul id="links">
                <li class="lien_page"><a href="{{ path('port_infos_perso') }}">{% trans %}.navbar.infos_perso{% endtrans %}</a></li>
                <li class="lien_page"><a href="{{ path('port_competences') }}">{% trans %}.navbar.competences{% endtrans %}</a></li>
                <li class="lien_page"><a href="{{ path('port_projets') }}">{% trans %}.navbar.projets{% endtrans %}</a></li>
                <li class="lien_page last"><a href="{{ path('port_contact') }}">{% trans %}.navbar.contact{% endtrans %}</a></li>
            </ul>
        </div>
        {% set locale = app.request.attributes.get('_locale') %}
        {% for uneLocale in supported_locales | split('|') %}
            {% if uneLocale != locale %}
                <div class="locale_changer">
                    {% set route = app.request.attributes.get('_route') %}
                    {% set params = app.request.attributes.get('_route_params') %}
                    {% set params = params | merge({'_locale': uneLocale }) %}
                    <a href="{{ path(route, params) }}">
                        <img src="{{ asset("images/locales/" ~ uneLocale ~ ".png") }}" alt="{{ uneLocale }}">
                    </a>
                </div>
            {% endif %}
        {% endfor %}
    </nav>
</header>
{% endblock %}
